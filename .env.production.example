# Humiley Procurement — production environment. Copy to `.env` on the server and edit.
#   cp .env.production.example .env
# deploy.sh generates AUTH_SECRET for you on first run if you leave it blank.

# ── Database (the bundled Postgres container) ──────────────────────────────────────────────
POSTGRES_USER=procurement
POSTGRES_PASSWORD=            # REQUIRED — set a strong value (openssl rand -hex 24)
POSTGRES_DB=humiley_procurement

# ── Auth.js ────────────────────────────────────────────────────────────────────────────────
AUTH_SECRET=                  # leave blank → deploy.sh fills it once (openssl rand -hex 32)

# ── No-second-login SSO from the portal ──────────────────────────────────────────────────────
# MUST be byte-for-byte equal to the portal's TK_SSO_SECRET (in /opt/humiley-timekeeping/.env),
# or the handoff silently falls back to the procurement login screen.
PORTAL_SSO_SECRET=

# ── Public URL + app config ──────────────────────────────────────────────────────────────────
APP_URL=https://procurement.humiley.com
PROCUREMENT_DOMAIN=procurement.humiley.com
DEFAULT_VAT_PCT=10

# First-run admin (only used by `./deploy.sh --bootstrap`; the password is printed once).
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_NAME=System Administrator

# ── Networking (advanced) ────────────────────────────────────────────────────────────────────
# Where to publish the app port on the host. Default 127.0.0.1 keeps it private so a Caddy in
# front proxies it. Only set 0.0.0.0 if nothing fronts the app.
PROCUREMENT_BIND=127.0.0.1
PROCUREMENT_PORT=3000

# ── Email (optional — notifications) ─────────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=procurement@humiley.com
